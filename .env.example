# LLM provider: openrouter | openai
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# модели: extractor (per-meeting) — smart, вспомогательное — cheap
LLM_MODEL_CHEAP=openai/gpt-4o-mini
LLM_MODEL_SMART=openai/gpt-4o

# Цены моделей ($/1M токенов) — используются для расчёта стоимости извлечения и планирования
PRICE_CHEAP_IN=0.15
PRICE_CHEAP_OUT=0.60
PRICE_SMART_IN=2.50
PRICE_SMART_OUT=10.00

# Whisper (транскрибация)
WHISPER_MODEL=base
WHISPER_LANGUAGE=ru

# захват аудио (Windows, VB-Cable) — имена устройств sounddevice
SYSTEM_AUDIO_DEVICE=
MIC_DEVICE=

# Telegram (подтверждение действий агента)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Plane
PLANE_BASE_URL=
PLANE_API_TOKEN=
PLANE_WORKSPACE=
PLANE_PROJECT_ID=
